{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Multidimensional Agent Feedback Matrix",
  "type": "object",
  "required": ["task_id", "agent_id", "status", "feedback_vector"],
  "properties": {
    "task_id": { "type": "string", "pattern": "^T-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}$" },
    "agent_id": { "type": "string" },
    "status": { "enum": ["completed", "failed", "partially_completed", "aborted"] },
    "timestamp_utc": { "type": "string", "format": "date-time" },
    "feedback_vector": {
      "type": "object",
      "required": ["metrics", "confidence", "anomalies"],
      "properties": {
        "metrics": {
          "type": "object",
          "properties": {
            "cpu_usage_pct": { "type": "number", "minimum": 0, "maximum": 100 },
            "memory_mb": { "type": "number" },
            "iops": { "type": "integer" },
            "duration_ms": { "type": "number" }
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Probability score of the task result accuracy."
        },
        "anomalies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "signature": { "type": "string" },
              "severity": { "enum": ["low", "medium", "high", "critical"] },
              "description": { "type": "string" }
            }
          }
        },
        "cascades": {
          "type": "array",
          "items": { "type": "string", "description": "Linked event IDs in the chain." }
        },
        "signal": {
          "type": "object",
          "properties": {
            "rgb": { "type": "array", "items": { "type": "integer" }, "minItems": 3, "maxItems": 3 },
            "frequency_hz": { "type": "number" }
          }
        }
      }
    }
  }
}
