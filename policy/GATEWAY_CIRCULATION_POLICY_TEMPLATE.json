      "restricted": ["local", "archive"],
      "governance": ["local", "archive", "gdrive"],
      "memory": ["local", "archive", "gdrive"],
      "artifacts": ["local", "archive", "gdrive", "onedrive"],
      "generic": ["local", "archive", "gdrive", "onedrive"]
