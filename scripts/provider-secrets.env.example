# Copy to scripts/provider-secrets.env and set real values.

# Cloud roots (local sync mirrors)
export LAM_GWS_DRIVE_ROOT="/path/to/GoogleDrive"
export GATEWAY_ONEDRIVE_ROOT="/path/to/OneDrive"

# External AI/API channels
export OPENAI_API_KEY=""
export ANTHROPIC_API_KEY=""
export XAI_API_KEY=""
export SHINKAI_API_URL=""

# Optional local model gateway
export OLLAMA_PORT="11434"

# Optional strict list for critical feedback under lockdown/failsafe
export LAM_FEEDBACK_CRITICAL_ALLOWED="openai,claude_sonnet,grok_xai,shinkai,github,google,microsoft"

